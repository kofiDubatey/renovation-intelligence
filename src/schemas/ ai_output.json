{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RIN_AI_Analysis_Output",
  "description": "The formal data contract for image analysis outputs.",
  "type": "object",
  "properties": {
    "room_type": {
      "type": "string",
      "enum": ["Kitchen", "Bathroom", "Bedroom", "Living_Room", "Exterior", "Other"]
    },
    "condition_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "detected_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "renovation_action": {
      "type": "string",
      "enum": ["Patch_and_Repair", "Partial_Renovation", "Full_Gut"]
    },
    "material_grade": {
      "type": "string",
      "enum": ["Builder_Grade", "Standard", "Luxury"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": ["room_type", "condition_score", "renovation_action", "confidence"]
}
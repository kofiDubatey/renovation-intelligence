{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RIN AI Analysis Output Schema",
  "description": "Schema for AI analysis output from Gemini AI for renovation intelligence",
  "type": "object",
  "required": [
    "room_type",
    "condition_score",
    "detected_issues",
    "renovation_action",
    "material_grade",
    "confidence"
  ],
  "properties": {
    "room_type": {
      "type": "string",
      "enum": ["Kitchen", "Bathroom", "Bedroom", "Living_Room", "Exterior", "Other"],
      "description": "Identifies the space being analyzed"
    },
    "condition_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Condition rating where 1=Distressed, 5=New/Excellent"
    },
    "detected_issues": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of visible problems detected",
      "examples": ["water_damage", "mold", "cracks", "stains"]
    },
    "renovation_action": {
      "type": "string",
      "enum": ["Patch_and_Repair", "Partial_Renovation", "Full_Gut"],
      "description": "The recommended level of renovation work"
    },
    "material_grade": {
      "type": "string",
      "enum": ["Builder_Grade", "Standard", "Luxury"],
      "description": "Quality level of existing finishes and materials"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "AI confidence level in the analysis result"
    }
  },
  "additionalProperties": false
}